<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!--Bean object of POJO class  (Student.java)   with name stdID-->
    <!--Bean obj can acces the properties of POJO class i.e. Student class-->
    <bean class="in.sk.bean.Address" id="addr">
        <property name="houseno" value="111"/>
        <property name="city" value="Kandri"/>
        <property name="pincode" value="441914"/>
    </bean>
    <bean class="in.sk.bean.Student" id="std">
        <property name="rollno"   value="101"/>
        <property name="name"    value="Sakshi"/>
        <property name="address"  ref="addr"/>  <!--provode bean obj of address class with id addr  in ref attribute-->

    </bean>
</beans>